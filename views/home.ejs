<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body class="bg-slate-900 text-slate-100 font-sans min-h-screen flex items-center justify-center p-4">

    <div
        class="w-full max-w-md bg-slate-800/50 backdrop-blur-md border border-slate-700/50 p-6 rounded-2xl shadow-xl transition-all">

        <div class="flex items-center gap-3 mb-6">
            <div class="bg-indigo-600 p-2.5 rounded-xl shadow-lg shadow-indigo-600/30">
                <i data-lucide="link-2" class="w-6 h-6 text-white"></i>
            </div>
            <div>
                <h1 class="text-xl font-bold tracking-tight text-white">URL Shortener</h1>
                <p class="text-xs text-slate-400">Shorten your long links instantly</p>
            </div>
        </div>

        <% if (locals.id) { %>
            <div class="mb-6 p-4 bg-slate-900/60 border border-emerald-500/30 rounded-xl animate-fade-in">
                <div
                    class="text-xs font-semibold text-emerald-400 uppercase tracking-wider mb-2 flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
                    Link Generated Successfully
                </div>

                <div
                    class="flex items-center justify-between bg-slate-900 p-2.5 rounded-lg border border-slate-700/50 gap-2">
                    <a id="shortUrl" href="http://localhost:8000/url/<%= id %>" target="_blank"
                        class="text-indigo-400 hover:text-indigo-300 font-medium text-sm truncate select-all transition-colors">
                        http://localhost:8000/url/<%= id %>
                    </a>
                    <button onclick="copyToClipboard()"
                        class="p-2 hover:bg-slate-800 rounded-md text-slate-400 hover:text-white transition-colors group relative"
                        title="Copy Link">
                        <i data-lucide="copy" class="w-4 h-4"></i>
                    </button>
                </div>

                <div class="mt-3 pt-3 border-t border-slate-800/60">
                    <p class="text-xs text-slate-400 truncate">
                        <span class="font-medium text-slate-500">Original:</span>
                        <%= originalUrl %>
                    </p>
                </div>
            </div>
            <% } %>

                <form method="post" action="/url" class="space-y-4">
                    <div>
                        <label for="url-input" class="block text-xs font-medium text-slate-400 mb-2">
                            Destination URL
                        </label>
                        <div class="relative">
                            <div
                                class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-500">
                                <i data-lucide="globe" class="w-4 h-4"></i>
                            </div>
                            <input id="url-input" type="url" name="url" required
                                placeholder="https://example.com/your-long-link-here"
                                class="w-full pl-10 pr-4 py-3 bg-slate-900/50 border border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 text-sm placeholder-slate-500 transition-all text-white" />
                        </div>
                    </div>

                    <button type="submit"
                        class="w-full py-3 px-4 bg-indigo-600 hover:bg-indigo-500 text-white font-medium rounded-xl shadow-lg shadow-indigo-600/20 hover:shadow-indigo-600/30 active:scale-[0.98] transition-all flex items-center justify-center gap-2 text-sm group">
                        Shorten Link
                        <i data-lucide="arrow-right"
                            class="w-4 h-4 group-hover:translate-x-0.5 transition-transform"></i>
                    </button>
                </form>
    </div>

    <script>
        // Initialize Lucide Icons
        lucide.createIcons();

        // Clipboard Copy Logic
        function copyToClipboard() {
            const urlText = document.getElementById('shortUrl').href;
            navigator.clipboard.writeText(urlText).then(() => {
                // Change icon temporarily to a checkmark
                const copyBtn = document.querySelector('[onclick="copyToClipboard()"]');
                copyBtn.innerHTML = '<i data-lucide="check" class="w-4 h-4 text-emerald-400"></i>';
                lucide.createIcons();

                // Revert icon after 2 seconds
                setTimeout(() => {
                    copyBtn.innerHTML = '<i data-lucide="copy" class="w-4 h-4"></i>';
                    lucide.createIcons();
                }, 2000);
            }).catch(err => {
                console.error('Failed to copy text: ', err);
            });
        }
    </script>
</body>

</html>